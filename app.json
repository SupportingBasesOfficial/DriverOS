{
  "expo": {
    "name": "DriverOS",
    "slug": "driveros",
    "version": "1.0.0",
    "scheme": "driveros",
    "orientation": "portrait",
    "userInterfaceStyle": "automatic",
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.supportingbases.driveros",
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "Para rastrear a rota das suas viagens",
        "NSLocationAlwaysAndWhenInUseUsageDescription": "Para rastrear rotas em segundo plano durante o turno"
      }
    },
    "android": {
      "package": "com.supportingbases.driveros",
      "permissions": [
        "ACCESS_FINE_LOCATION",
        "ACCESS_COARSE_LOCATION",
        "ACCESS_BACKGROUND_LOCATION"
      ]
    },
    "web": {
      "bundler": "metro",
      "output": "static"
    },
    "plugins": [
      [
        "expo-router",
        {
          "root": "./src/app"
        }
      ],
      "expo-asset",
      "expo-font",
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "Para rastrear a rota das suas viagens",
          "isIosBackgroundLocationEnabled": true,
          "isAndroidBackgroundLocationEnabled": true
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {
        "origin": false
      },
      "eas": {
        "projectId": "5c659be3-2a37-4682-b580-5bd6b1a12d43"
      }
    },
    "owner": "mauricioreuterneto"
  }
}
